<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- Same reasoning as the WPF app's own win-x64.pubxml: R2R inflates the single-file blob for
         no measured startup win this app has needed so far - keep it off unless profiling says
         otherwise. -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <!-- Compression OFF (item 17, same reasoning as the WPF app's own win-x64.pubxml): compressed
         bundle entries cannot be memory-mapped, so every managed assembly this app loads gets
         decompressed into PRIVATE COMMITTED MEMORY for the process lifetime - a real chunk of a
         resident tray app's idle working set. Uncompressed entries are mapped straight from the
         exe on disk (file-backed, shareable, evictable pages). Trade-off: the exe grows on disk;
         for an installed always-running app, idle RAM beats disk size. -->
    <EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
  </PropertyGroup>
</Project>
