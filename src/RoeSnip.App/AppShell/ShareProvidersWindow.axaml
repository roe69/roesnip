<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RoeSnip.App.AppShell.ShareProvidersWindow"
        Title="Sharing providers"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="18">
    <TextBlock DockPanel.Dock="Top" Text="Sharing providers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <TextBlock DockPanel.Dock="Top" Foreground="#FF9A9A9A" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
               Text="Every provider below is just a web request (endpoint, headers, and how to find the returned URL) - built-ins are pre-filled, 'Custom...' lets you point RoeSnip at any compatible upload API of your own."/>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button x:Name="AddCustomButton" Content="Custom..." Click="AddCustomButton_Click"/>
      <Button x:Name="CloseButton" Content="Close" Click="CloseButton_Click"/>
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="ProvidersListPanel"/>
    </ScrollViewer>
  </DockPanel>
</Window>
