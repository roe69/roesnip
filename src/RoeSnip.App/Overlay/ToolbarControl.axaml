<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RoeSnip.App.Overlay.ToolbarControl"
             Focusable="False"
             Cursor="Arrow"
             UseLayoutRounding="True">
    <UserControl.Styles>
        <!-- All icons are inline vector Path geometries (no image assets) — the same path data
             mini-language strings as the frozen WPF ToolbarControl.xaml. Uniform stretch into a
             14x14 box; round caps/joins. Stroke is the RL cream body-text color (item 16) rather
             than a flat white — every icon stays this one color regardless of button state (ghost
             fills/tints do the state signaling instead), except the two buttons whose rest fill is
             itself bright orange (Copy) or orange-tinted (Save), which override Stroke locally —
             see those buttons below. -->
        <Style Selector="Path.icon">
            <Setter Property="Stroke" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="StrokeThickness" Value="1.6"/>
            <Setter Property="StrokeLineCap" Value="Round"/>
            <Setter Property="StrokeJoin" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <!-- Focusable=False everywhere: clicking a toolbar button must never move keyboard focus
             off the overlay window, so Esc/Enter/Ctrl+... always reach the window's key handler.
             The size ComboBox is the one deliberate exception (see its own comment below) — typing
             a value needs real keyboard focus, exactly like WPF's SizeComboBox.

             Quiet-until-hovered (transparent rest state), matching WPF ToolButtonStyle: hover/press
             is a flat neutral tint (v_ghost), the active tool gets a flat orange tint PLUS a solid
             2px inset bar along the bottom edge — structure, not a color-washed fill, carries the
             selected state (design-no-fading-glow-accents: no gradients/glows here either). -->
        <Style Selector="ToggleButton.tool">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"/>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border x:Name="ActiveBar" Height="2" VerticalAlignment="Bottom"
                                Background="{StaticResource RlPrimaryGoldBrush}"
                                CornerRadius="0,0,5,5" IsVisible="False"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.tool:pointerover /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlGhostHoverBrush}"/>
        </Style>
        <Style Selector="ToggleButton.tool:pressed /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.tool:checked /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlActiveTintBrush}"/>
        </Style>
        <Style Selector="ToggleButton.tool:checked /template/ Border#ActiveBar">
            <Setter Property="IsVisible" Value="True"/>
        </Style>

        <!-- Quiet action (WPF QuietActionButtonStyle): the same v_ghost look as the tool buttons —
             transparent at rest, a flat orange tint on hover/press — used for Undo/Redo/SaveHdr/
             Share/ShareMenu, none of which is THE one primary action of the row. -->
        <Style Selector="Button.action">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.action:pointerover /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlGhostHoverBrush}"/>
        </Style>
        <Style Selector="Button.action:pressed /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
        </Style>
        <Style Selector="Button.action:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>

        <!-- Primary action (WPF ActionButtonStyle): solid orange fill, dark-on-primary text/icon, a
             solid primary-dark edge. Flat color swaps only on hover/press — no gradient, no glow.
             Used for Copy, the single most common terminal action. -->
        <Style Selector="Button.action-primary">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="{StaticResource RlPrimaryGoldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextOnPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlGoldBorderSolidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.action-primary:pointerover /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlPrimaryGoldLightBrush}"/>
        </Style>
        <Style Selector="Button.action-primary:pressed /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlGoldBorderSolidBrush}"/>
        </Style>
        <!-- Disabled opacity matches Button.action's icon-button 0.4, not a full-button 0.5 — Copy
             never actually goes disabled today, but keep it consistent if that changes. -->
        <Style Selector="Button.action-primary:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- Secondary action (WPF SecondaryActionButtonStyle): translucent orange fill + orange
             text/icon, warming up further on hover. One weight quieter than action-primary — used
             for Save. -->
        <Style Selector="Button.action-secondary">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="{StaticResource RlActiveTintBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlPrimaryGoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlSecondaryBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.action-secondary:pointerover /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlPrimaryGoldBrush}"/>
        </Style>
        <Style Selector="Button.action-secondary:pointerover">
            <Setter Property="Foreground" Value="{StaticResource RlPrimaryGoldLightBrush}"/>
        </Style>
        <Style Selector="Button.action-secondary:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- The Cancel X: quiet until hovered, then unmistakably red — the admonition-danger
             literal (RlDangerHoverBrush, #DC2626), not a softer approximation. Always fully closes
             the overlay (never a staged Esc behavior). Always visible — no hover-only reveal. -->
        <Style Selector="Button.cancel">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.cancel:pointerover /template/ Border#Bg">
            <Setter Property="Background" Value="{StaticResource RlDangerHoverBrush}"/>
        </Style>

        <Style Selector="ToggleButton.swatch">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlBorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.swatch:pointerover /template/ Border#Bg">
            <Setter Property="BorderBrush" Value="{StaticResource RlTextMutedBrush}"/>
        </Style>
        <!-- Checked ring uses the SITE's brand orange (not a generic white outline), so the
             selected swatch reads as "the brand color says yes" rather than a plain highlight. -->
        <Style Selector="ToggleButton.swatch:checked /template/ Border#Bg">
            <Setter Property="BorderBrush" Value="{StaticResource RlPrimaryGoldBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource RlPanelBackgroundBrush}" CornerRadius="12"
            BorderBrush="{StaticResource RlBorderStrongBrush}" BorderThickness="1">
        <StackPanel Margin="6">
            <!-- Row 1: tools + size (left) | Undo/Redo (right), an Auto|*|Auto Grid so both rows
                 span the same width and the panel reads symmetrically — mirrors WPF's own Row 1
                 layout (ToolbarControl.xaml:558-637). -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="ToolsGroupPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="SelectToolButton" Classes="tool"
                                  ToolTip.Tip="Select / move (default)" IsChecked="True">
                        <Path Classes="icon" StrokeDashArray="2.2,1.6" Data="M1,1 H15 V15 H1 Z"/>
                    </ToggleButton>
                    <ToggleButton x:Name="RectToolButton" Classes="tool" ToolTip.Tip="Rectangle">
                        <Path Classes="icon" Data="M1,3 H15 V13 H1 Z"/>
                    </ToggleButton>
                    <ToggleButton x:Name="EllipseToolButton" Classes="tool" ToolTip.Tip="Ellipse">
                        <Path Classes="icon" Data="M1,8 A7,5 0 1 1 15,8 A7,5 0 1 1 1,8"/>
                    </ToggleButton>
                    <ToggleButton x:Name="ArrowToolButton" Classes="tool" ToolTip.Tip="Arrow">
                        <Path Classes="icon" Data="M2,14 L13,3 M13,3 H7.5 M13,3 V8.5"/>
                    </ToggleButton>
                    <ToggleButton x:Name="LineToolButton" Classes="tool" ToolTip.Tip="Line">
                        <Path Classes="icon" Data="M2,14 L14,2"/>
                    </ToggleButton>
                    <ToggleButton x:Name="FreehandToolButton" Classes="tool" ToolTip.Tip="Freehand">
                        <Path Classes="icon" Data="M1,13 C3,4 6,4 8,9 C10,14 13,13 15,4"/>
                    </ToggleButton>
                    <ToggleButton x:Name="HighlightToolButton" Classes="tool"
                                  ToolTip.Tip="Highlighter: translucent marker (scroll wheel adjusts width)">
                        <!-- Chisel-tip marker: angled body with a flat tip stroke at the paper line -->
                        <Path Classes="icon" Data="M4,9 L9,4 L12,7 L7,12 Z M7,12 L4,9 M2,14 H7"/>
                    </ToggleButton>
                    <ToggleButton x:Name="PixelateToolButton" Classes="tool"
                                  ToolTip.Tip="Pixelate: censor a region (scroll wheel adjusts block size)">
                        <!-- Mosaic grid -->
                        <Path Classes="icon" StrokeThickness="1.2" Data="M2,2 H14 V14 H2 Z M6,2 V14 M10,2 V14 M2,6 H14 M2,10 H14"/>
                    </ToggleButton>
                    <ToggleButton x:Name="TextToolButton" Classes="tool" ToolTip.Tip="Text">
                        <Path Classes="icon" Data="M3,2 H13 M8,2 V14"/>
                    </ToggleButton>

                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <!-- Numeric size input (item 08 — replaced the fixed small/medium/big stroke
                         dots): shows "Npx" (stroke width) for the drawing tools and "Npt" (font
                         size) while the Text tool is active; dropdown offers preset jumps, typed
                         values are clamped by SizeInput. Enter commits and returns focus to the
                         overlay window (see ToolbarControl.axaml.cs). -->
                    <ComboBox x:Name="SizeComboBox" Width="76" Margin="2" VerticalAlignment="Center"
                              IsEditable="True" IsTextSearchEnabled="False"
                              ToolTip.Tip="Size: type a value or pick a preset (scroll wheel over the image also resizes)"/>
                </StackPanel>

                <StackPanel x:Name="HistoryGroupPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <!-- Undo/Redo sit at a FIXED spot (before the collapsible text-style row), so
                         switching to the Text tool never shoves them sideways mid-reach. Both start
                         disabled; OverlayWindow drives IsEnabled from the annotation history
                         (SetHistoryState) so an inapplicable action is visibly grayed out. -->
                    <Button x:Name="UndoButton" Classes="action" IsEnabled="False" ToolTip.Tip="Undo (Ctrl+Z)">
                        <!-- Curved undo arrow: head pointing left, tail sweeping down and back -->
                        <Path Classes="icon" Data="M2,6 L6,2 M2,6 L6,10 M2,6 H10 A4.5,4.5 0 0 1 10,15 H6"/>
                    </Button>
                    <Button x:Name="RedoButton" Classes="action" IsEnabled="False" ToolTip.Tip="Redo (Ctrl+Y)">
                        <!-- Mirrored undo arrow -->
                        <Path Classes="icon" Data="M14,6 L10,2 M14,6 L10,10 M14,6 H6 A4.5,4.5 0 0 0 6,15 H10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Height="1" Margin="1,4" Background="{StaticResource RlBorderStrongBrush}"/>

            <!-- Row 2: the editable palette (bottom-left) | terminal actions (bottom-right) —
                 mirrors WPF's own Row 2 layout (ToolbarControl.xaml:641-770). -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Every swatch is built in code from the persisted RoeSnipSettings.PaletteColors
                     list (via SwatchPalette) and carries a right-click "Replace..." context menu —
                     the only palette edit: the row's slot count never changes. -->
                <StackPanel x:Name="ColorSwatchPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Width="1" Margin="8,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <Button x:Name="CopyButton" Classes="action-primary" ToolTip.Tip="Copy (Ctrl+C)">
                        <!-- Two overlapping squares. Stroke overridden to the on-primary dark ink —
                             this button's fill is bright orange, so the shared cream Path.icon
                             default would read poorly here. -->
                        <Path Classes="icon" Stroke="{StaticResource RlTextOnPrimaryBrush}"
                              Data="M5.5,5.5 H14.5 V14.5 H5.5 Z M10.5,5.5 V1.5 H1.5 V10.5 H5.5"/>
                    </Button>
                    <Button x:Name="SaveButton" Classes="action-secondary" ToolTip.Tip="Save (Ctrl+S)">
                        <!-- Down-arrow into tray. Stroke overridden to the site's primary orange so
                             it matches this button's orange text/border (v_secondary recipe). -->
                        <Path Classes="icon" Stroke="{StaticResource RlPrimaryGoldBrush}"
                              Data="M8,1 V9 M4.5,5.5 L8,9 L11.5,5.5 M1.5,11 V14.5 H14.5 V11"/>
                    </Button>
                    <Button x:Name="SaveHdrButton" Classes="action"
                            ToolTip.Tip="Save HDR original (.jxr, untouched FP16)">
                        <!-- Save glyph with a small HDR badge -->
                        <Grid>
                            <Path Classes="icon" Width="13" Height="13" Margin="0,0,7,4"
                                  Data="M8,1 V9 M4.5,5.5 L8,9 L11.5,5.5 M1.5,11 V14.5 H14.5 V11"/>
                            <Border Background="{StaticResource RlBgSecondaryBrush}" CornerRadius="2" Padding="1.5,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                <TextBlock Text="HDR" FontSize="6.5" FontWeight="Bold"
                                           Foreground="{StaticResource RlPrimaryGoldBrush}"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <!-- Record: left-click opens the format menu (item 21 - unlike Save's
                         right-click-only HDR menu, Record has no single default format to pick for
                         a plain click). Picking a format closes the overlay and hands off to
                         RecordingOrchestrator (Setup/Recording/Reviewing chrome next to the
                         recorded region) - see OverlayController.OverlaySession.Record. -->
                    <Button x:Name="RecordButton" Classes="action" ToolTip.Tip="Record as MP4 or GIF">
                        <Grid IsHitTestVisible="False">
                            <Ellipse Width="13" Height="13" Stroke="{StaticResource RlTextPrimaryBrush}" StrokeThickness="1.5"/>
                            <Ellipse Width="6" Height="6" Fill="#DC4646"/>
                        </Grid>
                    </Button>

                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <!-- Share: uploads the current selection render to a configured Sharing/*
                         provider (item 12). A real split button (not a single-click-opens-menu
                         pattern): ShareButton's own click uploads straight to the DEFAULT provider
                         (one click, mirrors Copy/Save), while ShareMenuButton is a SEPARATE,
                         always-visible chevron affordance (no-hidden-controls: a control that opens
                         a menu must show it can, never rely on hover) opening a menu to pick a
                         specific configured provider instead. Both start disabled — the owning
                         window enables them via SetShareProviders once at least one provider is
                         configured (see that method's own doc comment for why this control never
                         enables itself). Mirrors the WPF app's own ShareGroupPanel. -->
                    <StackPanel x:Name="ShareGroupPanel" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ShareButton" Classes="action" Width="30" Margin="2,2,0,2" IsEnabled="False"
                                ToolTip.Tip="Share: no provider configured yet — set one up in Settings"
                                ToolTip.ShowOnDisabled="True">
                            <!-- Inverse of Save's down-arrow-into-tray: an up-arrow out of the tray. -->
                            <Path Classes="icon" Data="M8,9 V1 M4.5,4.5 L8,1 L11.5,4.5 M1.5,11 V14.5 H14.5 V11"/>
                        </Button>
                        <Button x:Name="ShareMenuButton" Classes="action" Width="16" Margin="0,2,2,2" IsEnabled="False"
                                ToolTip.Tip="Choose a provider to share to" ToolTip.ShowOnDisabled="True">
                            <Path Fill="{StaticResource RlDropdownArrowBrush}" Data="M0,0 L4,4 L8,0 Z" Width="8" Height="4"
                                  Stretch="Uniform" IsHitTestVisible="False"/>
                        </Button>
                    </StackPanel>

                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <Button x:Name="CancelButton" Classes="cancel" ToolTip.Tip="Cancel — close without capturing">
                        <Path Classes="icon" Width="11" Height="11" Data="M2,2 L14,14 M14,2 L2,14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Row 3: text style (item 08; mirrors WPF's ToolbarControl.xaml:772-793) — only ever
                 visible while the Text tool is active. A separate bottom row (leading hairline
                 inside, so it collapses with the panel) so the panel grows downward instead of
                 stretching Row 1 sideways. The font list is every installed system family (see
                 ToolbarControl.axaml.cs's FontFamilyChoices); the font size itself lives in
                 SizeComboBox (pt mode for the Text tool). -->
            <StackPanel x:Name="TextStylePanel" IsVisible="False">
                <Border Height="1" Margin="1,4" Background="{StaticResource RlBorderStrongBrush}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="BoldToggleButton" Classes="tool" Width="26"
                                  Content="B" FontWeight="Bold" ToolTip.Tip="Bold"/>
                    <ToggleButton x:Name="ItalicToggleButton" Classes="tool" Width="26"
                                  Content="I" FontStyle="Italic" FontWeight="Bold" ToolTip.Tip="Italic"/>

                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <ComboBox x:Name="FontFamilyComboBox" Width="220" Margin="2" VerticalAlignment="Center"
                              Focusable="False"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
