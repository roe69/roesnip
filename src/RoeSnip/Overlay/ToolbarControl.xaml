<UserControl x:Class="RoeSnip.Overlay.ToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             Cursor="Arrow"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <!-- All icons are inline vector Path geometries (no image assets). Uniform stretch into a
             14x14 box; round caps/joins for a clean hand-drawn-free look. -->
        <Style x:Key="IconStyle" TargetType="Path">
            <Setter Property="Stroke" Value="#F0F0F0"/>
            <Setter Property="StrokeThickness" Value="1.6"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <!-- Focusable=False everywhere: clicking a toolbar button must never move keyboard focus
             off the overlay window, so Esc/Enter/Ctrl+... always reach the window's key handler. -->
        <Style x:Key="ToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Active tool is visually obvious: solid accent fill. -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#3A7CFD"/>
                                <Setter Property="BorderBrush" Value="#5C9CFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#8A8A92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The Cancel X: quiet until hovered, then unmistakably red. Always fully closes the
             overlay (never the staged Esc behavior). -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorSwatchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="White"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark right-click menu chrome shared by the palette swatches ("Replace... / Remove")
             and the Save button ("Save HDR"). Retemplated for the same reason as DarkComboBoxStyle:
             the default menu chrome draws system-themed (light) regardless of Background setters.
             Cursor=Arrow explicitly — menus live in their own Popup visual tree, so they don't
             inherit the toolbar's own Arrow (item 1, UX round 5). -->
        <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#22222A"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#4A4A52"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="3"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent" Padding="10,6" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A7CFD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6A6A72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The numeric size input (item 2, UX round 5 — replaced the fixed small/medium/big stroke
             dots): an EDITABLE dark ComboBox, so unlike DarkComboBoxStyle it must template in the
             PART_EditableTextBox WPF's ComboBox looks up by name to enable typing. The TextBox is
             the one deliberately focusable control on the whole toolbar (typing needs real keyboard
             focus) — the session keyboard hook knows to stand down while it holds focus via
             OverlayWindow.IsTextInputFocused (see OverlayInputInterop.cs). -->
        <Style x:Key="DarkEditableComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}" CaretBrush="#EAEAEA"
                                             SelectionBrush="#3A7CFD"
                                             Margin="{TemplateBinding Padding}" Padding="0"
                                             VerticalContentAlignment="Center"
                                             Cursor="IBeam"/>
                                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                                  Background="Transparent" BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path Fill="#B8B8C0" Data="M0,0 L4,4 L8,0 Z"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="#22222A" BorderBrush="#4A4A52"
                                        BorderThickness="1" CornerRadius="4" Cursor="Arrow"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The "+" custom-color swatch: same round footprint as ColorSwatchStyle but (unlike that
             style's template) actually presents its child content, since this button needs the "+"
             glyph rather than a flat color fill. -->
        <Style x:Key="AddCustomColorButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#8A8A92"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Font-family dropdown item template: a fixed-size, standard-UI-font label on the left
             (always legible regardless of which family it names) plus a small "AaBb" sample
             rendered in that item's own family on the right — used for both the closed selection
             box and the open dropdown's rows (WPF applies ItemTemplate to both by default). -->
        <DataTemplate x:Key="FontFamilyItemTemplate">
            <Grid Margin="1,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding}" FontFamily="Segoe UI" FontSize="13"
                           Foreground="#EAEAEA" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="AaBb" FontFamily="{Binding}" FontSize="13"
                           Foreground="#A8A8B2" Margin="12,0,2,0" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- Explicit dark styling for every dropdown row (background/foreground for both the
             ComboBoxItem chrome and its hover/selected states) — separate from the ComboBox's own
             chrome styling below, since the Popup's items are a distinct visual subtree. -->
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#3A7CFD"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2F5FCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fully retemplated (not just a palette tweak) so both the closed chrome AND the dropdown
             Popup are explicitly dark — the default ComboBox template otherwise draws its Popup with
             a system-themed (typically light) brush regardless of the Background/Foreground setters
             above it, which is exactly why the plain-property version of this style read as
             illegible on the dark overlay. -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="#B8B8C0" Data="M0,0 L4,4 L8,0 Z"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                               Content="{TemplateBinding SelectionBoxItem}"
                                               ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                               ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                               Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <!-- Cursor=Arrow: the dropdown lives in its own Popup visual tree, so it does
                                     not inherit the toolbar root's Arrow (item 1, UX round 5). -->
                                <Border x:Name="DropDownBorder" Background="#22222A" BorderBrush="#4A4A52"
                                        BorderThickness="1" CornerRadius="4" Cursor="Arrow"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#EE1B1B1D" CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="1">
        <StackPanel Orientation="Horizontal" Margin="4">
            <!-- Tools -->
            <ToggleButton x:Name="SelectToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Select / move (default)" IsChecked="True" Click="OnSelectToolClick">
                <Path Style="{StaticResource IconStyle}" StrokeDashArray="2.2 1.6" Data="M1,1 H15 V15 H1 Z"/>
            </ToggleButton>
            <ToggleButton x:Name="RectToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Rectangle" Click="OnRectToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M1,3 H15 V13 H1 Z"/>
            </ToggleButton>
            <ToggleButton x:Name="EllipseToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Ellipse" Click="OnEllipseToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M1,8 A7,5 0 1 1 15,8 A7,5 0 1 1 1,8"/>
            </ToggleButton>
            <ToggleButton x:Name="ArrowToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Arrow" Click="OnArrowToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M2,14 L13,3 M13,3 H7.5 M13,3 V8.5"/>
            </ToggleButton>
            <ToggleButton x:Name="LineToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Line" Click="OnLineToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M2,14 L14,2"/>
            </ToggleButton>
            <ToggleButton x:Name="FreehandToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Freehand" Click="OnFreehandToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M1,13 C3,4 6,4 8,9 C10,14 13,13 15,4"/>
            </ToggleButton>
            <ToggleButton x:Name="TextToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Text" Click="OnTextToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M3,2 H13 M8,2 V14"/>
            </ToggleButton>

            <Border Width="1" Margin="4,3" Background="#3F3F46"/>

            <!-- The single editable palette (item 3, UX round 5): every swatch is built in code from
                 the persisted RoeSnipSettings.PaletteColors list and carries a right-click
                 Replace/Remove menu; the "+" swatch appends. The old separate CustomColorPanel row
                 is gone — custom and preset colors are one list now. -->
            <StackPanel x:Name="ColorSwatchPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
            <ToggleButton x:Name="AddCustomColorButton" Style="{StaticResource AddCustomColorButtonStyle}"
                          ToolTip="Add color..." Click="OnAddCustomColorClick">
                <Path Style="{StaticResource IconStyle}" Width="10" Height="10" Data="M7,1 V13 M1,7 H13"/>
            </ToggleButton>

            <Border Width="1" Margin="4,3" Background="#3F3F46"/>

            <!-- Numeric size input (item 2, UX round 5 — replaced the small/medium/big stroke dots):
                 shows "Npx" (stroke width) for the drawing tools and "Npt" (font size) while the
                 Text tool is active; dropdown offers preset jumps, typed values are clamped by
                 SizeInput. Enter commits and returns focus to the overlay window. -->
            <ComboBox x:Name="SizeComboBox" Style="{StaticResource DarkEditableComboBoxStyle}"
                      Width="74" Margin="2" VerticalAlignment="Center"
                      IsEditable="True" IsTextSearchEnabled="False"
                      ToolTip="Size — type a value or pick a preset (scroll wheel over the image also resizes)"
                      KeyDown="OnSizeComboKeyDown"
                      SelectionChanged="OnSizeComboSelectionChanged"/>

            <Border Width="1" Margin="4,3" Background="#3F3F46"/>

            <!-- Text-style group (item 4): only ever visible while the Text tool is active. The font
                 size itself moved into SizeComboBox (which switches to pt mode for the Text tool). -->
            <StackPanel x:Name="TextStylePanel" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                <ToggleButton x:Name="BoldToggleButton" Style="{StaticResource ToolButtonStyle}" Width="26"
                              Content="B" FontWeight="Bold" Click="OnBoldToggleClick" ToolTip="Bold"/>
                <ToggleButton x:Name="ItalicToggleButton" Style="{StaticResource ToolButtonStyle}" Width="26"
                              Content="I" FontStyle="Italic" FontWeight="Bold" Click="OnItalicToggleClick" ToolTip="Italic"/>

                <Border Width="1" Margin="4,3" Background="#3F3F46"/>

                <ComboBox x:Name="FontFamilyComboBox" Style="{StaticResource DarkComboBoxStyle}"
                          ItemTemplate="{StaticResource FontFamilyItemTemplate}"
                          Width="190" Margin="2" VerticalAlignment="Center"
                          SelectionChanged="OnFontFamilyChanged"/>
            </StackPanel>

            <Border Width="1" Margin="4,3" Background="#3F3F46"/>

            <Button x:Name="UndoButton" Style="{StaticResource ActionButtonStyle}"
                    ToolTip="Undo (Ctrl+Z)" Click="OnUndoClick">
                <!-- Curved undo arrow: head pointing left, tail sweeping down and back -->
                <Path Style="{StaticResource IconStyle}" Data="M2,6 L6,2 M2,6 L6,10 M2,6 H10 A4.5,4.5 0 0 1 10,15 H6"/>
            </Button>

            <Border Width="1" Margin="4,3" Background="#3F3F46"/>

            <Button x:Name="CopyButton" Style="{StaticResource ActionButtonStyle}" Background="#2E7D32"
                    ToolTip="Copy (Ctrl+C)" Click="OnCopyClick">
                <!-- Two overlapping squares -->
                <Path Style="{StaticResource IconStyle}" Data="M5.5,5.5 H14.5 V14.5 H5.5 Z M10.5,5.5 V1.5 H1.5 V10.5 H5.5"/>
            </Button>
            <!-- HDR export moved off the toolbar (item 4, UX round 5): 99% of saves are plain PNGs,
                 so left-click Save = PNG exactly as before and the old dedicated Save-HDR button is
                 now a right-click menu item here, raising the same SaveHdr command path unchanged. -->
            <Button x:Name="SaveButton" Style="{StaticResource ActionButtonStyle}" Background="#1565C0"
                    ToolTip="Save (Ctrl+S) — right-click for HDR" Click="OnSaveClick">
                <Button.ContextMenu>
                    <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                        <MenuItem x:Name="SaveHdrMenuItem" Style="{StaticResource DarkMenuItemStyle}"
                                  Header="Save HDR (.jxr)" Click="OnSaveHdrClick"
                                  ToolTip="Save the untouched FP16 HDR original (no annotations)"/>
                    </ContextMenu>
                </Button.ContextMenu>
                <!-- Down-arrow into tray -->
                <Path Style="{StaticResource IconStyle}" Data="M8,1 V9 M4.5,5.5 L8,9 L11.5,5.5 M1.5,11 V14.5 H14.5 V11"/>
            </Button>

            <Border Width="1" Margin="4,3" Background="#3F3F46"/>

            <Button x:Name="CancelButton" Style="{StaticResource CancelButtonStyle}"
                    ToolTip="Cancel — close without capturing" Click="OnCancelClick">
                <Path Style="{StaticResource IconStyle}" Width="11" Height="11" Data="M2,2 L14,14 M14,2 L2,14"/>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
