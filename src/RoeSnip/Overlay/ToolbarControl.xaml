<UserControl x:Class="RoeSnip.Overlay.ToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False"
             Cursor="Arrow"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <!-- Design tokens lifted from the roelite-net site's CSS custom properties. Now tracking
             roeshare's NEUTRAL palette (E:\GitHub\RoeLite\roeshare\public\css\tokens.css): a cool
             near-black foundation with hairline WHITE-ALPHA glass borders and ONE hot accent, the
             brand ORANGE, reserved for primary actions / the active item / focus. The old warm
             cream/gold interpretation is gone — gold is now only a rare accent elsewhere in the
             product, not this toolbar's primary. Every color used below routes through one of these
             so the toolbar reads as the same product as the site instead of a generic dark-mode dev
             tool. Alpha-tinted colors are pre-multiplied hex (#AARRGGBB) since WPF brushes don't take
             a separate opacity channel the way CSS rgba() does. -->
        <SolidColorBrush x:Key="RlTextPrimaryBrush" Color="#EDEDF0"/>
        <!-- rl-text: neutral off-white body/icon color, ~16:1 on black — never pure white. -->
        <SolidColorBrush x:Key="RlTextMutedBrush" Color="#A2A2AB"/>
        <!-- rl-text-muted -->
        <SolidColorBrush x:Key="RlTextDimBrush" Color="#71717B"/>
        <!-- rl-text-dim: disabled/label text -->
        <SolidColorBrush x:Key="RlTextOnPrimaryBrush" Color="#180D07"/>
        <!-- dark text placed on bright orange fills -->
        <SolidColorBrush x:Key="RlPrimaryGoldBrush" Color="#FF6B35"/>
        <!-- rl-primary / rl-orange-400, the brand accent (primary action color; key name kept for
             XAML StaticResource stability) -->
        <SolidColorBrush x:Key="RlPrimaryGoldLightBrush" Color="#FF8A5C"/>
        <!-- rl-primary-light / rl-orange-300, primary-button hover fill -->
        <SolidColorBrush x:Key="RlGoldBorderSolidBrush" Color="#E5561F"/>
        <!-- rl-primary-dark / rl-orange-500, solid-color button edges + press fill -->
        <SolidColorBrush x:Key="RlBgSecondaryBrush" Color="#0E0E11"/>
        <!-- rl-bg-secondary: card fill, used here for popup/menu chrome -->
        <SolidColorBrush x:Key="RlBgElevatedBrush" Color="#18181D"/>
        <!-- rl-bg-elevated: nested chip/input fill -->
        <SolidColorBrush x:Key="RlBorderBrush" Color="#12FFFFFF"/>
        <!-- rl-border, rgba(255,255,255,.07): the workhorse hairline for inputs/menus -->
        <SolidColorBrush x:Key="RlBorderStrongBrush" Color="#24FFFFFF"/>
        <!-- rl-border-strong, rgba(255,255,255,.14): emphasized edges — the floating panel's own
             border and the toolbar's internal group dividers, both of which need to read clearly
             against arbitrary screenshot content rather than a consistent page background. -->
        <SolidColorBrush x:Key="RlSecondaryBorderBrush" Color="#2EFFFFFF"/>
        <!-- rgba(255,255,255,.18): v_secondary button border (Save) -->
        <SolidColorBrush x:Key="RlGhostHoverBrush" Color="#0FFFFFFF"/>
        <!-- rgba(255,255,255,.06): v_ghost hover fill (tool buttons, "+") -->
        <SolidColorBrush x:Key="RlGhostPressedBrush" Color="#1AFFFFFF"/>
        <!-- rgba(255,255,255,.10): v_ghost pressed fill / v_secondary hover fill / dropdown row hover -->
        <SolidColorBrush x:Key="RlActiveTintBrush" Color="#1FFF6B35"/>
        <!-- rgba(primary,.12): the flat background tint half of the site's active-item recipe —
             roeshare's active nav item/primary button use the one hot orange accent, so the active
             tool here gets an orange tint rather than a neutral one. -->
        <SolidColorBrush x:Key="RlSelectedItemBrush" Color="#33FF6B35"/>
        <!-- rgba(primary,.20): a still-flat, slightly stronger orange tint for a genuinely-selected
             dropdown row -->
        <SolidColorBrush x:Key="RlDangerHoverBrush" Color="#DC2626"/>
        <!-- rl-danger-600: solid hover fill for Cancel; the neutral-bright Cancel icon keeps enough
             contrast against this deeper red than the lighter rl-danger-400 coral would give. -->
        <SolidColorBrush x:Key="RlPanelBackgroundBrush" Color="#EB0E0E11"/>
        <!-- The Modal glass-card recipe (rgba(14,14,17,.5), rl-bg-secondary + hairline border, no
             blur attempt needed since the dimmed screenshot behind IS the blur) pushed from 50% to
             ~92% opacity: the product's dark-on-dim readability requirement means a floating toolbar
             can't be as translucent as a card sitting on the page's own near-black background. Same
             neutral near-black hue as the site, just less see-through. -->
        <SolidColorBrush x:Key="RlDropdownArrowBrush" Color="#A2A2AB"/>

        <!-- All icons are inline vector Path geometries (no image assets). Uniform stretch into a
             14x14 box; round caps/joins for a clean hand-drawn-free look. Stroke is the roelite-net
             cream body-text color rather than the old flat white — every icon stays this one color
             regardless of button state (ghost fills/tints do the state signaling instead), except
             the two buttons whose rest/hover fill is itself bright gold (Copy, Save), which override
             Stroke locally to the site's on-primary/accent text color for contrast. -->
        <Style x:Key="IconStyle" TargetType="Path">
            <Setter Property="Stroke" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="StrokeThickness" Value="1.6"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>

        <!-- Focusable=False everywhere: clicking a toolbar button must never move keyboard focus
             off the overlay window, so Esc/Enter/Ctrl+... always reach the window's key handler. -->
        <Style x:Key="ToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Active-tool indicator, roelite-net's "active item" recipe (a solid 2px
                                 inset bar on the leading edge, never a glow) rotated for a horizontal
                                 toolbar row: a flat 2px orange bar along the bottom edge. Structure, not
                                 color-washing the whole button, carries the selected state. -->
                            <Border x:Name="ActiveBar" Height="2" VerticalAlignment="Bottom"
                                    Background="{StaticResource RlPrimaryGoldBrush}"
                                    CornerRadius="0,0,7,7" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover/pressed = an ascending flat neutral tint (v_ghost), active tool =
                                 the site's flat active-tint + inset bar. Quiet-until-hovered (transparent
                                 rest state) reads far less busy than a wall of identical outlined squares. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlActiveTintBrush}"/>
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action per roelite-net's v_primary recipe: solid orange fill, dark-on-primary
             text, a solid primary-dark edge. Flat color swaps only on hover/press — no gradient, no
             glow — per the product's hard rule against colored glow/drop-shadow chrome. Used for
             Copy, the most common terminal action (the site's button hierarchy reserves
             solid-primary for exactly that: the one action most users take). -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="{StaticResource RlPrimaryGoldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextOnPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlGoldBorderSolidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlPrimaryGoldLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGoldBorderSolidBrush}"/>
                            </Trigger>
                            <!-- Disabled = clearly inert (undo with nothing to undo, redo with
                                 nothing undone) but still occupying its spot — no layout shifts. -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action per roelite-net's v_secondary recipe: translucent orange fill + orange
             text/icon, warming up further on hover. One weight quieter than ActionButtonStyle's
             solid-primary look — used for Save, which the site's button hierarchy would treat as the
             secondary of the pair (Copy being the more common single action). -->
        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="{StaticResource RlActiveTintBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlPrimaryGoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlSecondaryBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource RlPrimaryGoldBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource RlPrimaryGoldLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Undo/Redo (and any future secondary action): the same v_ghost look as the tool buttons —
             transparent at rest, a flat gold tint on hover/press — but a plain Button, sharing
             ActionButtonStyle's disabled-opacity trigger (icon-button disabled opacity is 0.4 per the
             site's IconButton spec, one notch lighter than a full Button's 0.5, since these are the
             icon-only analogue). -->
        <Style x:Key="QuietActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The Cancel X: quiet until hovered, then unmistakably red (the admonition-danger literal,
             not the softer rl-danger token — see RlDangerHoverBrush). Always fully closes the
             overlay (never the staged Esc behavior). -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlDangerHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorSwatchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlBorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource RlTextMutedBrush}"/>
                            </Trigger>
                            <!-- Checked ring uses the SITE's brand orange (not a generic white ring),
                                 so the selected swatch reads as "the brand color says yes" rather than
                                 a plain outline. -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource RlPrimaryGoldBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark right-click menu chrome shared by the palette swatches ("Replace... / Remove")
             and the Save button ("Save HDR"). Retemplated for the same reason as DarkComboBoxStyle:
             the default menu chrome draws system-themed (light) regardless of Background setters.
             Cursor=Arrow explicitly — menus live in their own Popup visual tree, so they don't
             inherit the toolbar's own Arrow (item 1, UX round 5). -->
        <Style x:Key="DarkContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource RlBgSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlBorderStrongBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="3"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent" Padding="10,6" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource RlTextDimBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkable variant of DarkMenuItemStyle for the record menu's audio toggles:
             DarkMenuItemStyle's template never looks at IsChecked, so a checkable item styled with
             it would toggle invisibly. This adds a fixed-width leading box that fills gold when
             checked - flat, no glyph font dependency. StaysOpenOnClick is set per item in the
             XAML so both toggles can be flipped without reopening the menu. -->
        <Style x:Key="DarkCheckMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent" Padding="10,6" SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center"
                                        CornerRadius="2" BorderThickness="1"
                                        BorderBrush="{StaticResource RlBorderStrongBrush}">
                                    <Border x:Name="CheckFill" Margin="2" CornerRadius="1"
                                            Background="Transparent"/>
                                </Border>
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckFill" Property="Background" Value="{StaticResource RlPrimaryGoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource RlTextDimBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Explicit dark styling for every dropdown row. DEFINED BEFORE both ComboBox styles that
             reference it: a StaticResource forward-reference inside a compiled ResourceDictionary
             hands ItemContainerStyle a deferred reference instead of a Style, which detonates as
             an InvalidCastException (process-killing XamlParseException) the first time the
             control is hovered — this exact bug crashed the tray in round 5 verification. -->
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlGhostPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource RlSelectedItemBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The numeric size input (item 2, UX round 5 — replaced the fixed small/medium/big stroke
             dots): an EDITABLE dark ComboBox, so unlike DarkComboBoxStyle it must template in the
             PART_EditableTextBox WPF's ComboBox looks up by name to enable typing. The TextBox is
             the one deliberately focusable control on the whole toolbar (typing needs real keyboard
             focus) — the session keyboard hook knows to stand down while it holds focus via
             OverlayWindow.IsTextInputFocused (see OverlayInputInterop.cs). -->
        <Style x:Key="DarkEditableComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource RlBgElevatedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}" CaretBrush="{StaticResource RlTextPrimaryBrush}"
                                             SelectionBrush="{StaticResource RlGhostPressedBrush}"
                                             Margin="{TemplateBinding Padding}" Padding="0"
                                             VerticalContentAlignment="Center"
                                             Cursor="IBeam"/>
                                    <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                                  Background="Transparent" BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path Fill="{StaticResource RlDropdownArrowBrush}" Data="M0,0 L4,4 L8,0 Z"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{StaticResource RlBgSecondaryBrush}" BorderBrush="{StaticResource RlBorderStrongBrush}"
                                        BorderThickness="1" CornerRadius="8" Cursor="Arrow"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True" ScrollViewer.CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Font-family dropdown item template: a fixed-size, standard-UI-font label on the left
             (always legible regardless of which family it names) plus a small "AaBb" sample
             rendered in that item's own family on the right — used for both the closed selection
             box and the open dropdown's rows (WPF applies ItemTemplate to both by default). -->
        <DataTemplate x:Key="FontFamilyItemTemplate">
            <Grid Margin="1,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding}" FontFamily="Segoe UI" FontSize="13"
                           Foreground="{StaticResource RlTextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="AaBb" FontFamily="{Binding}" FontSize="13"
                           Foreground="{StaticResource RlTextMutedBrush}" Margin="12,0,2,0" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- Fully retemplated (not just a palette tweak) so both the closed chrome AND the dropdown
             Popup are explicitly dark — the default ComboBox template otherwise draws its Popup with
             a system-themed (typically light) brush regardless of the Background/Foreground setters
             above it, which is exactly why the plain-property version of this style read as
             illegible on the dark overlay. -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource RlBgElevatedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource RlTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <!-- Virtualization matters now that FontFamilyComboBox holds every installed system
                 family (hundreds of rows, each rendering a live "AaBb" preview in its own font):
                 without it the first dropdown open would realize the entire list at once. Needs
                 both the panel below AND CanContentScroll=True on the template's ScrollViewer. -->
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="{StaticResource RlDropdownArrowBrush}" Data="M0,0 L4,4 L8,0 Z"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                               Content="{TemplateBinding SelectionBoxItem}"
                                               ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                               ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                               Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <!-- Cursor=Arrow: the dropdown lives in its own Popup visual tree, so it does
                                     not inherit the toolbar root's Arrow (item 1, UX round 5). -->
                                <Border x:Name="DropDownBorder" Background="{StaticResource RlBgSecondaryBrush}" BorderBrush="{StaticResource RlBorderStrongBrush}"
                                        BorderThickness="1" CornerRadius="8" Cursor="Arrow"
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="260">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True" ScrollViewer.CanContentScroll="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Double-stacked layout: row 1 is everything that CONFIGURES a drawing (tool, size, text
         style), row 2 is the palette plus the session actions (undo / copy / save / cancel) —
         keeps the toolbar roughly half as wide so it fits beside smaller selections.
         Panel surface follows the roelite-net Modal glass-card recipe (neutral near-black rgba fill +
         single hairline white-alpha border, 12px "popover" radius) — see RlPanelBackgroundBrush for
         why the opacity is pushed well past the site's own 50% glass. -->
    <Border Background="{StaticResource RlPanelBackgroundBrush}" CornerRadius="12" BorderBrush="{StaticResource RlBorderStrongBrush}" BorderThickness="1">
        <StackPanel Margin="6,5">
            <StackPanel Orientation="Horizontal">
            <!-- Tools -->
            <ToggleButton x:Name="SelectToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Select / move (default)" IsChecked="True" Click="OnSelectToolClick">
                <Path Style="{StaticResource IconStyle}" StrokeDashArray="2.2 1.6" Data="M1,1 H15 V15 H1 Z"/>
            </ToggleButton>
            <ToggleButton x:Name="RectToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Rectangle" Click="OnRectToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M1,3 H15 V13 H1 Z"/>
            </ToggleButton>
            <ToggleButton x:Name="EllipseToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Ellipse" Click="OnEllipseToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M1,8 A7,5 0 1 1 15,8 A7,5 0 1 1 1,8"/>
            </ToggleButton>
            <ToggleButton x:Name="ArrowToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Arrow" Click="OnArrowToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M2,14 L13,3 M13,3 H7.5 M13,3 V8.5"/>
            </ToggleButton>
            <ToggleButton x:Name="LineToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Line" Click="OnLineToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M2,14 L14,2"/>
            </ToggleButton>
            <ToggleButton x:Name="FreehandToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Freehand" Click="OnFreehandToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M1,13 C3,4 6,4 8,9 C10,14 13,13 15,4"/>
            </ToggleButton>
            <ToggleButton x:Name="HighlightToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Highlighter: translucent marker (scroll wheel adjusts width)" Click="OnHighlightToolClick">
                <!-- Chisel-tip marker: angled body with a flat tip stroke at the paper line -->
                <Path Style="{StaticResource IconStyle}" Data="M4,9 L9,4 L12,7 L7,12 Z M7,12 L4,9 M2,14 H7"/>
            </ToggleButton>
            <ToggleButton x:Name="PixelateToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Pixelate: censor a region (scroll wheel adjusts block size)" Click="OnPixelateToolClick">
                <!-- Mosaic grid -->
                <Path Style="{StaticResource IconStyle}" StrokeThickness="1.2" Data="M2,2 H14 V14 H2 Z M6,2 V14 M10,2 V14 M2,6 H14 M2,10 H14"/>
            </ToggleButton>
            <ToggleButton x:Name="TextToolButton" Style="{StaticResource ToolButtonStyle}"
                          ToolTip="Text" Click="OnTextToolClick">
                <Path Style="{StaticResource IconStyle}" Data="M3,2 H13 M8,2 V14"/>
            </ToggleButton>

            <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

            <!-- Numeric size input (item 2, UX round 5 — replaced the small/medium/big stroke dots):
                 shows "Npx" (stroke width) for the drawing tools and "Npt" (font size) while the
                 Text tool is active; dropdown offers preset jumps, typed values are clamped by
                 SizeInput. Enter commits and returns focus to the overlay window. -->
            <ComboBox x:Name="SizeComboBox" Style="{StaticResource DarkEditableComboBoxStyle}"
                      Width="74" Margin="2" VerticalAlignment="Center"
                      IsEditable="True" IsTextSearchEnabled="False"
                      ToolTip="Size: type a value or pick a preset (scroll wheel over the image also resizes)"
                      KeyDown="OnSizeComboKeyDown"
                      SelectionChanged="OnSizeComboSelectionChanged"/>

            <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

            <!-- Undo/Redo sit at a FIXED spot (before the collapsible text-style group), so
                 switching to the Text tool never shoves them sideways mid-reach. Both start
                 disabled; OverlayWindow drives IsEnabled from the annotation history
                 (SetHistoryState) so an inapplicable action is visibly grayed out. -->
            <Button x:Name="UndoButton" Style="{StaticResource QuietActionButtonStyle}"
                    IsEnabled="False" ToolTip="Undo (Ctrl+Z)" Click="OnUndoClick">
                <!-- Curved undo arrow: head pointing left, tail sweeping down and back -->
                <Path Style="{StaticResource IconStyle}" Data="M2,6 L6,2 M2,6 L6,10 M2,6 H10 A4.5,4.5 0 0 1 10,15 H6"/>
            </Button>
            <Button x:Name="RedoButton" Style="{StaticResource QuietActionButtonStyle}"
                    IsEnabled="False" ToolTip="Redo (Ctrl+Y)" Click="OnRedoClick">
                <!-- Mirrored undo arrow -->
                <Path Style="{StaticResource IconStyle}" Data="M14,6 L10,2 M14,6 L10,10 M14,6 H6 A4.5,4.5 0 0 0 6,15 H10"/>
            </Button>

            </StackPanel>

            <Border Height="1" Margin="1,4" Background="{StaticResource RlBorderStrongBrush}"/>

            <!-- Row 2 is now a Grid (Auto | * | Auto) instead of one left-aligned row, so it can hold
                 two visually distinct sections that both keep their natural width regardless of how
                 wide row 1 ends up: the editable palette stays pinned bottom-left, and the terminal
                 actions stay pinned bottom-right — hugging the panel's actual edge (via the star
                 column absorbing the slack) rather than just trailing after the palette. The
                 separation between them is a plain hairline divider immediately ahead of the action
                 group (roelite-net's structural-not-glow separator convention), not a boxed-in band —
                 the panel itself is already the one contained surface. -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- BOTTOM-LEFT: the fixed-size palette — every swatch is built in code from the
                     persisted RoeSnipSettings.PaletteColors list and carries a right-click
                     "Replace..." menu (the only palette edit: the row's slot count never changes,
                     so there is no add or remove). -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel x:Name="ColorSwatchPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- BOTTOM-RIGHT: the session actions, right-aligned so they hug the panel's real
                     edge via the Auto column + the star spacer column above soaking up the slack. -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Width="1" Margin="8,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <!-- Record: left-click opens the format menu (unlike Save's right-click-only HDR
                         menu — Record has no single default format to pick for a plain click). -->
                    <Button x:Name="RecordButton" Style="{StaticResource QuietActionButtonStyle}"
                            ToolTip="Record as MP4 or GIF" Click="OnRecordClick">
                        <Button.ContextMenu>
                            <!-- Placement/PlacementTarget set in the code-behind constructor (a
                                 ContextMenu isn't part of the Button's visual tree, so a XAML-time
                                 RelativeSource binding can't reach it) — see ToolbarControl(). -->
                            <ContextMenu x:Name="RecordContextMenu" Style="{StaticResource DarkContextMenuStyle}">
                                <MenuItem x:Name="RecordMp4MenuItem" Header="Record MP4" Style="{StaticResource DarkMenuItemStyle}" Click="OnRecordMp4Click"/>
                                <MenuItem x:Name="RecordGifMenuItem" Header="Record GIF" Style="{StaticResource DarkMenuItemStyle}" Click="OnRecordGifClick"/>
                                <Separator Background="{StaticResource RlBorderStrongBrush}" Margin="6,3" Height="1"/>
                                <!-- MP4 audio sources, persisted via OverlayWindow (GIF has no audio,
                                     so these only matter to the MP4 item above). StaysOpenOnClick so
                                     both can be flipped in one visit. -->
                                <MenuItem x:Name="RecordMicMenuItem" Header="Microphone"
                                          Style="{StaticResource DarkCheckMenuItemStyle}"
                                          IsCheckable="True" StaysOpenOnClick="True"
                                          ToolTip="Include microphone audio in MP4 recordings"
                                          Checked="OnAudioToggleChanged" Unchecked="OnAudioToggleChanged"/>
                                <MenuItem x:Name="RecordSystemAudioMenuItem" Header="System audio"
                                          Style="{StaticResource DarkCheckMenuItemStyle}"
                                          IsCheckable="True" StaysOpenOnClick="True"
                                          ToolTip="Include what you hear (system playback) in MP4 recordings"
                                          Checked="OnAudioToggleChanged" Unchecked="OnAudioToggleChanged"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <!-- Record icon, restyled to sit with its stroked siblings: the same cream
                             1.5px outline ring every other icon uses, with a small flat red core as
                             the record affordance. The old solid 10px red dot carried far more visual
                             weight than the line-drawn icons around it. -->
                        <Grid IsHitTestVisible="False">
                            <Ellipse Width="13" Height="13" Stroke="{StaticResource RlTextPrimaryBrush}" StrokeThickness="1.5"/>
                            <Ellipse Width="6" Height="6" Fill="#DC4646"/>
                        </Grid>
                    </Button>

                    <!-- Upload: placeholder for the upcoming upload plugins (imgur-style and custom
                         image API integrations). Disabled until the first integration ships, but
                         already visible so the action group's final shape is established.
                         ShowOnDisabled so the tooltip still explains what it is. Icon is the
                         inverse of Save's down-arrow-into-tray: an up-arrow out of the tray. -->
                    <Button x:Name="UploadButton" Style="{StaticResource QuietActionButtonStyle}"
                            IsEnabled="False" ToolTip="Upload (integrations coming soon)"
                            ToolTipService.ShowOnDisabled="True">
                        <!-- No extra opacity here: QuietActionButtonStyle's own IsEnabled=False
                             trigger already dims the whole button, same as undo/redo. -->
                        <Path Style="{StaticResource IconStyle}"
                              Data="M8,9 V1 M4.5,4.5 L8,1 L11.5,4.5 M1.5,11 V14.5 H14.5 V11"/>
                    </Button>

                    <Button x:Name="CopyButton" Style="{StaticResource ActionButtonStyle}"
                            ToolTip="Copy (Ctrl+C)" Click="OnCopyClick">
                        <!-- Two overlapping squares. Stroke overridden to the on-primary dark ink —
                             this button's fill is bright gold, so the shared cream IconStyle default
                             would read poorly here. -->
                        <Path Style="{StaticResource IconStyle}" Stroke="{StaticResource RlTextOnPrimaryBrush}"
                              Data="M5.5,5.5 H14.5 V14.5 H5.5 Z M10.5,5.5 V1.5 H1.5 V10.5 H5.5"/>
                    </Button>
                    <!-- HDR export moved off the toolbar (item 4, UX round 5): 99% of saves are plain PNGs,
                         so left-click Save = PNG exactly as before and the old dedicated Save-HDR button is
                         now a right-click menu item here, raising the same SaveHdr command path unchanged. -->
                    <Button x:Name="SaveButton" Style="{StaticResource SecondaryActionButtonStyle}"
                            ToolTip="Save (Ctrl+S), right-click for HDR" Click="OnSaveClick">
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                <MenuItem x:Name="SaveHdrMenuItem" Style="{StaticResource DarkMenuItemStyle}"
                                          Header="Save HDR (.jxr)" Click="OnSaveHdrClick"
                                          ToolTip="Save the untouched FP16 HDR original (no annotations)"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <!-- Down-arrow into tray. Stroke overridden to the site's primary gold so it
                             matches this button's gold text/border (v_secondary recipe). -->
                        <Path Style="{StaticResource IconStyle}" Stroke="{StaticResource RlPrimaryGoldBrush}"
                              Data="M8,1 V9 M4.5,5.5 L8,9 L11.5,5.5 M1.5,11 V14.5 H14.5 V11"/>
                    </Button>

                    <Button x:Name="CancelButton" Style="{StaticResource CancelButtonStyle}"
                            ToolTip="Cancel: close without capturing" Click="OnCancelClick">
                        <Path Style="{StaticResource IconStyle}" Width="11" Height="11" Data="M2,2 L14,14 M14,2 L2,14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Text-style row (item 4; moved out of row 1): only ever visible while the Text tool
                 is active. A separate BOTTOM row (leading hairline INSIDE, so it collapses with the
                 panel) — the panel grows downward instead of stretching row 1 sideways, keeping the
                 two permanent rows' layout stable no matter which tool is active. The font list is
                 every installed system family (see ToolbarControl.xaml.cs FontFamilyChoices); the
                 font size itself lives in SizeComboBox (pt mode for the Text tool). -->
            <StackPanel x:Name="TextStylePanel" Visibility="Collapsed">
                <Border Height="1" Margin="1,4" Background="{StaticResource RlBorderStrongBrush}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="BoldToggleButton" Style="{StaticResource ToolButtonStyle}" Width="26"
                                  Content="B" FontWeight="Bold" Click="OnBoldToggleClick" ToolTip="Bold"/>
                    <ToggleButton x:Name="ItalicToggleButton" Style="{StaticResource ToolButtonStyle}" Width="26"
                                  Content="I" FontStyle="Italic" FontWeight="Bold" Click="OnItalicToggleClick" ToolTip="Italic"/>

                    <Border Width="1" Margin="4,3" Background="{StaticResource RlBorderStrongBrush}"/>

                    <ComboBox x:Name="FontFamilyComboBox" Style="{StaticResource DarkComboBoxStyle}"
                              ItemTemplate="{StaticResource FontFamilyItemTemplate}"
                              Width="230" Margin="2" VerticalAlignment="Center"
                              SelectionChanged="OnFontFamilyChanged"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
