<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- R2R off (was true): RoeSnip.csproj already sets TieredCompilation=false and pays every
         method's full-opt JIT cost up front on the warmup thread, so R2R's normal "skip tier-0 JIT
         at startup" benefit is mostly redundant here - R2R just inflates the single-file blob with
         precompiled native code for all target architectures. Measured: dropped process-start-to-
         warmup-complete from ~2.3s to ~1.3s (fewer bytes to map off disk) with warm hotkey-to-dim
         and first-overlay-visible unchanged (~5 ms / ~130 ms) - net win on both size and startup. -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- WPF ships ~15 localized satellite resource sets (PresentationCore.resources.dll etc.) that
         this app never localizes into; en-only keeps just the neutral culture's resources. -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <!-- Compression OFF (was true; idle-memory work, 2026-07): compressed bundle entries cannot be
         memory-mapped, so every managed assembly the app loads gets DECOMPRESSED INTO PRIVATE
         COMMITTED MEMORY for the process lifetime (~60-150 MB of the observed ~1 GB idle private
         bytes; the WPF+WinRT+Vortice payload is 178 MB uncompressed). Uncompressed entries are
         mapped straight from the exe on disk - file-backed, shareable, evictable pages that barely
         count against the resident tray's private bytes. Trade-off: the exe grows back from ~69 MB
         toward ~180 MB on disk; for an installed always-running app, idle RAM beats disk size. -->
    <EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
  </PropertyGroup>
</Project>
