<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- R2R off (was true): RoeSnip.csproj already sets TieredCompilation=false and pays every
         method's full-opt JIT cost up front on the warmup thread, so R2R's normal "skip tier-0 JIT
         at startup" benefit is mostly redundant here - R2R just inflates the single-file blob with
         precompiled native code for all target architectures. Measured: dropped process-start-to-
         warmup-complete from ~2.3s to ~1.3s (fewer bytes to map off disk) with warm hotkey-to-dim
         and first-overlay-visible unchanged (~5 ms / ~130 ms) - net win on both size and startup. -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- WPF ships ~15 localized satellite resource sets (PresentationCore.resources.dll etc.) that
         this app never localizes into; en-only keeps just the neutral culture's resources. -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <!-- Single biggest win (~110 MB): the self-contained runtime + WPF/WinForms/Vortice payload
         compresses well. Costs one-time LZMA extraction into a per-app-version temp cache at
         process start (~500 ms, measured), which lands before the warmup thread starts and is
         invisible to the user - RoeSnip is a resident tray app that launches once and stays
         warm, not a CLI that pays this cost on every invocation. -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>
</Project>
