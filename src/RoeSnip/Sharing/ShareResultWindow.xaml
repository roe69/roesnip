<Window x:Class="RoeSnip.Sharing.ShareResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoeSnip"
        Icon="pack://application:,,,/Assets/roesnip.ico"
        Width="360" Height="150"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        BorderThickness="1"
        BorderBrush="#12FFFFFF"
        Background="#FF18181D"
        Foreground="#FFEDEDF0"
        FontFamily="Segoe UI"
        FontSize="12.5"
        KeyDown="Window_KeyDown"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        Closed="Window_Closed">
    <!-- Same tokens as ShareProviderEditWindow.xaml/SettingsWindow.xaml - duplicated locally,
         matching this codebase's existing per-window resource style. -->
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF0E0E12"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF9A9AA3"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE05A5A"/>

        <Style TargetType="Button" x:Key="ToastButton">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="#12FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: provider name + always-visible close (no hover-reveal). -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HeaderText" Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button x:Name="CloseButton" Grid.Column="1" Content="&#x2715;" Click="CloseButton_Click"
                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource MutedBrush}"
                    Padding="4,0" Cursor="Hand"/>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="1" Margin="0,6,0,0" TextWrapping="Wrap"/>

        <ProgressBar x:Name="ProgressBarControl" Grid.Row="1" VerticalAlignment="Bottom" Height="4"
                     Margin="0,0,0,-6" IsIndeterminate="True" Visibility="Collapsed"/>

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBox x:Name="LinkText" x:FieldModifier="private" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     Background="{StaticResource PanelBrush}" Foreground="#FFEDEDF0" BorderBrush="#12FFFFFF"
                     Padding="6,4" Visibility="Collapsed"/>
            <TextBlock x:Name="KeptPathText" Margin="0,6,0,0" TextWrapping="Wrap"
                       Foreground="{StaticResource MutedBrush}" FontSize="11" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel x:Name="ButtonsPanel" Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource ToastButton}"
                    Click="CancelButton_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="OpenButton" Content="Open" Style="{StaticResource ToastButton}"
                    Click="OpenButton_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="CopyButton" Content="Copy" Style="{StaticResource ToastButton}"
                    Click="CopyButton_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
