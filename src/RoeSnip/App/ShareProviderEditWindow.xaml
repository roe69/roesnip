<Window x:Class="RoeSnip.App.ShareProviderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure provider"
        Icon="pack://application:,,,/Assets/roesnip.ico"
        Width="460" SizeToContent="Height"
        MaxHeight="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF000000"
        Foreground="#FFEDEDF0"
        FontFamily="Segoe UI"
        FontSize="13">
    <!-- Same tokens as SettingsWindow.xaml/ShareProvidersWindow.xaml - duplicated locally, matching
         this codebase's existing per-window resource style. -->
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF18181D"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFF6B35"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF71717B"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#FFDC6B2E"/>
        <SolidColorBrush x:Key="OkBrush" Color="#FF4A9EFF"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFDC2626"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#FFEDEDF0"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#FFEDEDF0"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18">
            <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock x:Name="UntestedBadgeText" Foreground="{StaticResource WarnBrush}" FontSize="11"
                       TextWrapping="Wrap" Margin="0,0,0,6" Visibility="Collapsed"/>
            <TextBlock x:Name="NotesText" Foreground="{StaticResource MutedBrush}" FontSize="11"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>

            <Label Content="Display name"/>
            <TextBox x:Name="DisplayNameBox" Margin="0,0,0,10"/>
            <CheckBox x:Name="EnabledCheckBox" Content="Enabled (offered as an upload target)"/>

            <!-- Built-in provider: one Label+TextBox/PasswordBox pair per ProviderSpec.ConfigFields
                 entry, built in code (ShareProviderEditWindow.xaml.cs BuildBuiltInFields) since the
                 set of fields depends entirely on which provider this is. -->
            <StackPanel x:Name="BuiltInFieldsPanel" Margin="0,10,0,0"/>

            <!-- Custom provider: the full ProviderSpec editable directly - only shown when editing/
                 adding a Custom entry (see ShareProviderConfig.IsCustom). -->
            <StackPanel x:Name="CustomSpecPanel" Visibility="Collapsed" Margin="0,10,0,0">
                <TextBlock Text="Request" FontWeight="SemiBold" Margin="0,4,0,8"/>

                <Label Content="Endpoint URL (may use {Key} tokens - see Template values below)"/>
                <TextBox x:Name="EndpointBox" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="HTTP method"/>
                        <TextBox x:Name="MethodBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="Upload kind"/>
                        <ComboBox x:Name="UploadKindCombo" SelectionChanged="UploadKindCombo_SelectionChanged">
                            <ComboBoxItem Content="Multipart form (most services)"/>
                            <ComboBoxItem Content="Raw file bytes (e.g. RoeShare)"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="MultipartOnlyPanel">
                    <Label Content="Multipart field name for the file (default: file)"/>
                    <TextBox x:Name="MultipartFieldNameBox" Margin="0,0,0,10"/>
                    <Label Content="Extra form fields, one per line: name=value (may use {Key} tokens)"/>
                    <TextBox x:Name="ExtraFieldsBox" AcceptsReturn="True" TextWrapping="Wrap" Height="56" Margin="0,0,0,10"/>
                </StackPanel>

                <Label Content="Headers, one per line: Name: value (may use {Key} tokens)"/>
                <TextBox x:Name="HeadersBox" AcceptsReturn="True" TextWrapping="Wrap" Height="56" Margin="0,0,0,10"/>

                <Label Content="Max upload size in MB (blank = unknown/unbounded)"/>
                <TextBox x:Name="MaxSizeMbBox" Margin="0,0,0,10"/>

                <TextBlock Text="Response" FontWeight="SemiBold" Margin="0,4,0,8"/>
                <Label Content="How to find the URL in a successful response"/>
                <ComboBox x:Name="ResponseModeCombo" Margin="0,0,0,10" SelectionChanged="ResponseModeCombo_SelectionChanged">
                    <ComboBoxItem Content="JSON path (e.g. data.link)"/>
                    <ComboBoxItem Content="Regex (URL is capture group 1)"/>
                    <ComboBoxItem Content="Whole response body is the URL"/>
                </ComboBox>
                <StackPanel x:Name="ResponseJsonPathPanel">
                    <Label Content="JSON path"/>
                    <TextBox x:Name="ResponseJsonPathBox" Margin="0,0,0,10"/>
                </StackPanel>
                <StackPanel x:Name="ResponseRegexPanel">
                    <Label Content="Regex"/>
                    <TextBox x:Name="ResponseRegexBox" Margin="0,0,0,10"/>
                </StackPanel>

                <TextBlock Text="Template values" FontWeight="SemiBold" Margin="0,4,0,8"/>
                <Label Content="One per line: Key=Value (e.g. ApiKey=..., BaseUrl=https://example.com) - referenced above as {Key}"/>
                <TextBox x:Name="CustomValuesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="56" Margin="0,0,0,10"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,10"
                       Text="Values (including API keys/tokens) are stored in plain text in settings.json, same as every other RoeSnip setting - do not use a credential you can't afford to have read off disk."/>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button x:Name="TestButton" Content="Test" Click="TestButton_Click" Margin="0,0,8,0"/>
                <TextBlock x:Name="TestStatusText" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="RemoveButton" Content="Remove" Click="RemoveButton_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
                <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Margin="0,0,8,0"/>
                <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" Background="{StaticResource AccentBrush}" Foreground="#FF180D07"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
