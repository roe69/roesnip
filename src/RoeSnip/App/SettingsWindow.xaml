<Window x:Class="RoeSnip.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoeSnip Settings"
        Icon="pack://application:,,,/Assets/roesnip.ico"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF000000"
        Foreground="#FFEDEDF0"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <!-- Neutral near-black surfaces + one hot orange accent, tracking roeshare's design
             tokens (public/css/tokens.css) instead of a generic VS-dark-theme gray+blue look.
             Window background is pure #000 for OLED; PanelBrush is the elevated-surface tone
             used for inputs/buttons, BorderBrush2 is a white-alpha hairline (rgba(255,255,255,.07)
             pre-multiplied as WPF #AARRGGBB), AccentBrush is the roeshare primary orange. -->
        <SolidColorBrush x:Key="PanelBrush" Color="#FF18181D"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFF6B35"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFA2A2AB"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#FFEDEDF0"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">
        <TextBlock Text="RoeSnip Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14"/>

        <Label Content="Hotkey"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HotkeyDisplay" Grid.Column="0" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button x:Name="ChangeHotkeyButton" Grid.Column="1" Content="Change..." Click="ChangeHotkeyButton_Click"/>
        </Grid>

        <Label Content="Save directory"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SaveDirectoryBox" Grid.Column="0" Margin="0,0,8,0"/>
            <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse..." Click="BrowseButton_Click"/>
        </Grid>

        <CheckBox x:Name="AutoSaveHdrCheckBox" Content="Always save an HDR (.jxr) copy alongside the PNG"/>
        <CheckBox x:Name="CopyOnSelectCheckBox" Content="Confirming a selection also copies it to the clipboard"/>
        <CheckBox x:Name="ColorPickerCheckBox" Content="Enable the colour picker (click to pick a colour, loupe colour codes)"/>
        <CheckBox x:Name="RunAtStartupCheckBox" Content="Start RoeSnip when Windows starts"/>
        <TextBlock x:Name="RunAtStartupHintText" Margin="20,0,0,4" FontSize="11" Foreground="#FF71717B"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <CheckBox x:Name="RunElevatedCheckBox"
                  Content="Run as administrator (starts via scheduled task, no UAC prompt)"
                  Checked="RunElevatedCheckBox_Checked" Unchecked="RunElevatedCheckBox_Unchecked"/>
        <TextBlock x:Name="ElevationStatusText" Margin="20,0,0,4" FontSize="11" Foreground="#FF71717B"/>

        <TextBlock Text="Advanced tone-map overrides (leave blank for automatic)" Margin="0,14,0,6" Foreground="#FF71717B"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Knee (0-1)"/>
                <TextBox x:Name="KneeOverrideBox"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Peak"/>
                <TextBox x:Name="PeakOverrideBox"/>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" Background="{StaticResource AccentBrush}" Foreground="#FF180D07"/>
        </StackPanel>
    </StackPanel>
</Window>
