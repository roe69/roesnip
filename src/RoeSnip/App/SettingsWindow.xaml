<Window x:Class="RoeSnip.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RoeSnip Settings"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="#FFE8E8E8"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#FF3C3C3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4A9EFF"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFCFCFCF"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#FFE8E8E8"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">
        <TextBlock Text="RoeSnip Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14"/>

        <Label Content="Hotkey"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HotkeyDisplay" Grid.Column="0" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button x:Name="ChangeHotkeyButton" Grid.Column="1" Content="Change..." Click="ChangeHotkeyButton_Click"/>
        </Grid>

        <Label Content="Save directory"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SaveDirectoryBox" Grid.Column="0" Margin="0,0,8,0"/>
            <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse..." Click="BrowseButton_Click"/>
        </Grid>

        <CheckBox x:Name="AutoSaveHdrCheckBox" Content="Always save an HDR (.jxr) copy alongside the PNG"/>
        <CheckBox x:Name="CopyOnSelectCheckBox" Content="Confirming a selection also copies it to the clipboard"/>
        <CheckBox x:Name="RunAtStartupCheckBox" Content="Start RoeSnip when Windows starts"/>

        <TextBlock Text="Advanced tone-map overrides (leave blank for automatic)" Margin="0,14,0,6" Foreground="#FF9A9A9A"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Label Content="Knee (0-1)"/>
                <TextBox x:Name="KneeOverrideBox"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Peak"/>
                <TextBox x:Name="PeakOverrideBox"/>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" Background="{StaticResource AccentBrush}" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</Window>
