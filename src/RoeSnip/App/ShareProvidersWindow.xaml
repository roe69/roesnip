<Window x:Class="RoeSnip.App.ShareProvidersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sharing providers"
        Icon="pack://application:,,,/Assets/roesnip.ico"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#FF000000"
        Foreground="#FFEDEDF0"
        FontFamily="Segoe UI"
        FontSize="13">
    <!-- Same neutral near-black + one hot orange accent tokens as SettingsWindow.xaml - duplicated
         locally rather than shared via a ResourceDictionary, matching this codebase's existing
         per-window resource style (SettingsWindow.xaml does the same). -->
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FF18181D"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFFF6B35"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF71717B"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#FFDC6B2E"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEDEDF0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" Text="Sharing providers" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top" Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Every provider below is just a web request (endpoint, headers, and how to find the returned URL) - built-ins are pre-filled, 'Custom...' lets you point RoeSnip at any compatible upload API of your own."/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="AddCustomButton" Content="Custom..." Click="AddCustomButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="CloseButton" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ProvidersListPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>
